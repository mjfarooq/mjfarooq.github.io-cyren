---
import lab from "../data/lab.json";
const base = import.meta.env.BASE_URL;
const u = (p) => base.replace(/\/$/, "") + "/" + p.replace(/^\//, "");
const { transparent = false } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, "");
const here = (p) => path.endsWith(p);
const nav = [
  { p: "research", label: "Research" },
  { p: "team", label: "Team" },
  { p: "publications", label: "Publications" },
  { p: "news", label: "News" },
];
---
<header class={"nav" + (transparent ? " over" : "")}>
  <div class="wrap nav-in">
    <a class="brand" href={u("")}>
      <span class="brand-mark">CyReN</span>
      <span class="brand-sub">Cyber Resilient Networks</span>
    </a>
    <nav class="links" aria-label="Primary">
      {nav.map((n) => <a href={u(n.p)} class={here(n.p) ? "on" : ""}>{n.label}</a>)}
      <a class="join-link" href={u("news") + "#join"}>Join</a>
    </nav>
    <button class="burger" aria-label="Menu" onclick="document.body.classList.toggle('nav-open')">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
<style>
  .nav{position:sticky;top:0;z-index:50;background:#fff;border-bottom:1px solid var(--border);}
  .nav.over{position:fixed;left:0;right:0;background:transparent;border-bottom-color:transparent;}
  .nav.over.scrolled{position:fixed;background:#fff;border-bottom:1px solid var(--border);}
  .nav-in{display:flex;align-items:center;justify-content:space-between;height:70px;}
  .brand{display:flex;flex-direction:column;line-height:1;}
  .brand-mark{font-family:var(--ff-mono);font-weight:500;font-size:20px;letter-spacing:.02em;color:var(--blue);}
  .brand-sub{font-size:11px;color:var(--text-mute);letter-spacing:.04em;margin-top:3px;}
  .nav.over .brand-mark,.nav.over .brand-sub{color:#fff;}
  .nav.over.scrolled .brand-mark{color:var(--blue);}
  .nav.over.scrolled .brand-sub{color:var(--text-mute);}
  .links{display:flex;align-items:center;gap:1.7rem;}
  .links a{font-size:14.5px;color:var(--text-soft);font-weight:500;}
  .links a:hover{color:var(--blue);text-decoration:none;}
  .links a.on{color:var(--blue);}
  .nav.over .links a{color:#e7ecf2;}
  .nav.over.scrolled .links a{color:var(--text-soft);}
  .join-link{background:var(--maize);color:var(--blue)!important;padding:.45rem .9rem;border-radius:4px;font-weight:600;}
  .burger{display:none;flex-direction:column;gap:4px;background:none;border:0;cursor:pointer;padding:8px;}
  .burger span{width:22px;height:2px;background:var(--blue);border-radius:2px;}
  .nav.over .burger span{background:#fff;}
  .nav.over.scrolled .burger span{background:var(--blue);}
  @media(max-width:780px){
    .links{position:fixed;inset:70px 0 auto 0;flex-direction:column;gap:0;background:#fff;border-bottom:1px solid var(--border);padding:.4rem 0;transform:translateY(-130%);transition:transform .28s;}
    body.nav-open .links{transform:none;}
    .links a{padding:.85rem clamp(20px,5vw,52px);width:100%;border-top:1px solid var(--border);}
    .join-link{margin:.5rem clamp(20px,5vw,52px);width:auto;text-align:center;}
    .burger{display:flex;}
  }
</style>
