---
import Base from "../../layouts/Base.astro";
import pubs from "../../data/publications.json";
const types = ["All", "Journal", "Conference", "Book", "Book Chapter"];
const list = pubs.filter(p => p.type !== "Thesis");
function authorsHtml(s){ return s.replace(/(M\. J\. Farooq|J\. Farooq)/g, "<strong>$1</strong>"); }
---
<Base title="Publications" description="Publications from the CyReN Lab.">
  <section class="page-head"><div class="wrap"><span class="eyebrow">Publications</span><h1 class="h-xl">Publications</h1>
    <p class="lead">{list.length} works from the lab. An asterisk denotes a student advisee. See also <a href="https://scholar.google.com/citations?user=Per3ks8AAAAJ&hl=en" target="_blank" rel="noopener">Google Scholar</a>.</p></div></section>
  <section class="section">
    <div class="wrap">
      <div class="bar">
        <div class="search"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3" stroke-linecap="round"/></svg><input id="q" type="search" placeholder="Search publications…" autocomplete="off"/></div>
        <div class="chips" id="chips">{types.map((t) => <button class={"chip"+(t==="All"?" on":"")} data-t={t}>{t}</button>)}</div>
      </div>
      <div class="count" id="count">{list.length} results</div>
      <ol class="plist" id="plist">
        {list.map((p) => (
          <li class="pitem" data-type={p.type} data-s={(p.title+" "+p.authors_str+" "+p.venue+" "+p.tags.join(" ")).toLowerCase()}>
            <div class="pi-year">{p.year}</div>
            <div>
              <div class="pi-top"><span class={"badge b-"+p.type.toLowerCase().replace(" ","")}>{p.type}</span>{p.tags.slice(0,3).map((t)=><span class="tag">{t}</span>)}</div>
              {p.url ? <a class="pi-title" href={p.url} target="_blank" rel="noopener">{p.title}</a> : <span class="pi-title">{p.title}</span>}
              <div class="pi-auth" set:html={authorsHtml(p.authors_str)}></div>
              <div class="pi-venue">{p.venue}</div>
            </div>
          </li>
        ))}
      </ol>
      <div class="nores" id="nores" hidden>No matching publications.</div>
    </div>
  </section>
</Base>
<style>
  .page-head{padding:clamp(2.5rem,6vw,5rem) 0 0;}
  .bar{display:flex;gap:.8rem;flex-wrap:wrap;justify-content:space-between;align-items:center;margin:0 0 .6rem;}
  .search{display:flex;align-items:center;gap:.5rem;flex:1 1 240px;min-width:220px;border:1px solid var(--border-strong);border-radius:4px;padding:.1rem .8rem;color:var(--text-mute);}
  .search:focus-within{border-color:var(--blue);color:var(--blue);}
  #q{flex:1;border:0;outline:0;background:none;font-family:var(--ff-sans);font-size:14px;color:var(--text);padding:.55rem 0;}
  .chips{display:flex;flex-wrap:wrap;gap:.4rem;}
  .chip{font-family:var(--ff-mono);font-size:12px;padding:.42rem .7rem;border-radius:4px;background:#fff;border:1px solid var(--border);color:var(--text-soft);cursor:pointer;}
  .chip.on{background:var(--blue);color:#fff;border-color:var(--blue);}
  .count{font-family:var(--ff-mono);font-size:12px;color:var(--text-mute);margin:.4rem 0 1.2rem;}
  .plist{list-style:none;padding:0;margin:0;}
  .pitem{display:grid;grid-template-columns:54px 1fr;gap:1rem;padding:1.3rem 0;border-top:1px solid var(--border);}
  .pi-year{font-family:var(--ff-mono);font-size:13px;color:var(--link);}
  .pi-top{display:flex;flex-wrap:wrap;gap:.35rem;align-items:center;margin-bottom:.45rem;}
  .pi-title{font-family:var(--ff-serif);font-weight:600;font-size:1.1rem;color:var(--blue);line-height:1.3;}
  a.pi-title:hover{color:var(--link);}
  .pi-auth{font-size:.9rem;color:var(--text-soft);margin-top:.3rem;}
  .pi-auth strong{color:var(--blue);}
  .pi-venue{font-size:.85rem;color:var(--text-mute);font-style:italic;margin-top:.1rem;}
  .badge{font-family:var(--ff-mono);font-size:10px;text-transform:uppercase;letter-spacing:.05em;padding:.2rem .5rem;border-radius:3px;}
  .b-journal{background:#00274c;color:#fff;}.b-conference{background:#ffcb05;color:#00274c;}.b-book,.b-bookchapter{background:#1f5394;color:#fff;}
  .nores{padding:2.5rem 0;color:var(--text-mute);font-family:var(--ff-mono);}
  @media(max-width:560px){.pitem{grid-template-columns:1fr;gap:.3rem;}}
</style>
<script is:inline>
  (function(){
    var q=document.getElementById("q"),list=document.getElementById("plist");
    var items=[].slice.call(list.querySelectorAll(".pitem")),count=document.getElementById("count"),nores=document.getElementById("nores"),active="All";
    function apply(){var s=(q.value||"").trim().toLowerCase(),n=0;items.forEach(function(el){var okT=active==="All"||el.getAttribute("data-type")===active;var okS=!s||el.getAttribute("data-s").indexOf(s)!==-1;var show=okT&&okS;el.style.display=show?"":"none";if(show)n++;});count.textContent=n+(n===1?" result":" results");nores.hidden=n!==0;}
    q.addEventListener("input",apply);
    document.getElementById("chips").addEventListener("click",function(e){var b=e.target.closest(".chip");if(!b)return;active=b.getAttribute("data-t");document.querySelectorAll("#chips .chip").forEach(function(c){c.classList.toggle("on",c===b);});apply();});
  })();
</script>
