---
import Base from "../../layouts/Base.astro";
import pubs from "../../data/publications.json";
import { bibtex } from "../../data/bibtex.js";
const types = ["All", "Journal", "Conference", "Book", "Book Chapter"];
const list = pubs.filter(p => p.type !== "Thesis");
const years = Array.from(new Set(list.map((p) => p.year))).sort((a, b) => b - a);
const authorList = Array.from(new Set(list.flatMap((p) => p.authors || []))).sort((a, b) => a.localeCompare(b));
function authorsHtml(s){ return s.replace(/(M\. J\. Farooq|J\. Farooq)/g, "<strong>$1</strong>"); }
---
<Base title="Publications" description="Publications from the CyReN Lab.">
  <section class="page-head"><div class="wrap"><span class="eyebrow">Publications</span><h1 class="h-xl">Publications</h1>
    <p class="lead">An asterisk denotes a student advisee. The full record is also on <a href="https://scholar.google.com/citations?user=Per3ks8AAAAJ&hl=en" target="_blank" rel="noopener">Google Scholar</a>.</p></div></section>
  <section class="section">
    <div class="wrap">
      <div class="bar">
        <div class="search"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3" stroke-linecap="round"/></svg><input id="q" type="search" placeholder="Search publications…" autocomplete="off"/></div>
        <div class="chips" id="chips">{types.map((t) => <button class={"chip"+(t==="All"?" on":"")} data-t={t}>{t}</button>)}</div>
      </div>
      <div class="filters">
        <label class="fl"><span>Year</span>
          <select id="year"><option value="All">All years</option>{years.map((y) => <option value={y}>{y}</option>)}</select>
        </label>
        <label class="fl"><span>Author</span>
          <select id="author"><option value="All">All authors</option>{authorList.map((a) => <option value={a}>{a}</option>)}</select>
        </label>
      </div>
      <div class="count" id="count" style="display:none"></div>
      <ol class="plist" id="plist">
        {list.map((p) => (
          <li class="pitem" data-type={p.type} data-year={p.year} data-authors={(p.authors || []).join("|")} data-s={(p.title+" "+p.authors_str+" "+p.venue+" "+p.tags.join(" ")).toLowerCase()}>
            <div class="pi-year">{p.year}</div>
            <div>
              <div class="pi-top"><span class={"badge b-"+p.type.toLowerCase().replace(" ","")}>{p.type}</span>{p.tags.slice(0,3).map((t)=><span class="tag">{t}</span>)}</div>
              {p.url ? <a class="pi-title" href={p.url} target="_blank" rel="noopener">{p.title}</a> : <span class="pi-title">{p.title}</span>}
              <div class="pi-auth" set:html={authorsHtml(p.authors_str)}></div>
              <div class="pi-venue">{p.venue}</div>
              <div class="pi-links">
                {p.links && p.links.map((l) => <a class="pi-link" href={l.url} target="_blank" rel="noopener">{l.label}</a>)}
                <button class="pi-link pi-cite-toggle" type="button">BibTeX</button>
              </div>
              <div class="pi-cite-box" hidden>
                <button type="button" class="pi-copy" aria-label="Copy BibTeX">Copy</button>
                <pre class="pi-bib">{bibtex(p)}</pre>
              </div>
            </div>
          </li>
        ))}
      </ol>
      <div class="nores" id="nores" hidden>No matching publications.</div>
    </div>
  </section>
</Base>
<style>
  .page-head{padding:clamp(2.5rem,6vw,5rem) 0 0;}
  .bar{display:flex;gap:.8rem;flex-wrap:wrap;justify-content:space-between;align-items:center;margin:0 0 .6rem;}
  .search{display:flex;align-items:center;gap:.5rem;flex:1 1 240px;min-width:220px;border:1px solid var(--border-strong);border-radius:4px;padding:.1rem .8rem;color:var(--text-mute);}
  .search:focus-within{border-color:var(--blue);color:var(--blue);}
  #q{flex:1;border:0;outline:0;background:none;font-family:var(--ff-sans);font-size:14px;color:var(--text);padding:.55rem 0;}
  .chips{display:flex;flex-wrap:wrap;gap:.4rem;}
  .chip{font-family:var(--ff-mono);font-size:12px;padding:.42rem .7rem;border-radius:4px;background:#fff;border:1px solid var(--border);color:var(--text-soft);cursor:pointer;}
  .chip.on{background:var(--blue);color:#fff;border-color:var(--blue);}
  .count{font-family:var(--ff-mono);font-size:12px;color:var(--text-mute);margin:.4rem 0 1.2rem;}
  .filters{display:flex;flex-wrap:wrap;gap:.9rem;margin:.7rem 0 0;}
  .fl{display:flex;align-items:center;gap:.45rem;font-family:var(--ff-mono);font-size:12px;color:var(--text-mute);}
  .fl select{font-family:var(--ff-sans);font-size:13px;color:var(--text);background:#fff;border:1px solid var(--border-strong);border-radius:4px;padding:.4rem .6rem;cursor:pointer;max-width:220px;}
  .fl select:focus{outline:0;border-color:var(--blue);}
  .plist{list-style:none;padding:0;margin:0;}
  .pitem{display:grid;grid-template-columns:54px 1fr;gap:1rem;padding:1.3rem 0;border-top:1px solid var(--border);}
  .pi-year{font-family:var(--ff-mono);font-size:13px;color:var(--link);}
  .pi-top{display:flex;flex-wrap:wrap;gap:.35rem;align-items:center;margin-bottom:.45rem;}
  .pi-title{font-family:var(--ff-serif);font-weight:600;font-size:1.1rem;color:var(--blue);line-height:1.3;}
  a.pi-title:hover{color:var(--link);}
  .pi-auth{font-size:.9rem;color:var(--text-soft);margin-top:.3rem;}
  .pi-auth strong{color:var(--blue);}
  .pi-venue{font-size:.85rem;color:var(--text-mute);font-style:italic;margin-top:.1rem;}
  .pi-links{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.6rem;}
  .pi-link{font-family:var(--ff-mono);font-size:11px;letter-spacing:.03em;padding:.25rem .6rem;border:1px solid var(--border-strong);border-radius:5px;color:var(--link);background:#fff;}
  .pi-link:hover{background:var(--blue);color:#fff;border-color:var(--blue);text-decoration:none;}
  .pi-cite-toggle{font-family:var(--ff-mono);cursor:pointer;}
  .pi-cite-toggle.on{background:var(--blue);color:#fff;border-color:var(--blue);}
  .pi-cite-box{position:relative;margin-top:.6rem;}
  .pi-bib{background:#fff;border:1px solid var(--border);border-radius:6px;padding:.8rem 1rem;font-family:var(--ff-mono);font-size:11.5px;line-height:1.55;white-space:pre;overflow-x:auto;color:var(--text);margin:0;}
  .pi-copy{position:absolute;top:8px;right:8px;font-family:var(--ff-mono);font-size:11px;padding:.25rem .55rem;border:1px solid var(--border-strong);border-radius:5px;background:#fff;color:var(--link);cursor:pointer;}
  .pi-copy:hover{background:var(--blue);color:#fff;border-color:var(--blue);}
  .pi-copy.ok{background:var(--maize);color:var(--blue);border-color:var(--maize);}
  .badge{font-family:var(--ff-mono);font-size:10px;text-transform:uppercase;letter-spacing:.05em;padding:.2rem .5rem;border-radius:3px;}
  .b-journal{background:#00274c;color:#fff;}.b-conference{background:#ffcb05;color:#00274c;}.b-book,.b-bookchapter{background:#1f5394;color:#fff;}
  .nores{padding:2.5rem 0;color:var(--text-mute);font-family:var(--ff-mono);}
  @media(max-width:560px){.pitem{grid-template-columns:1fr;gap:.3rem;}}
</style>
<script is:inline>
  (function(){
    var q=document.getElementById("q"),list=document.getElementById("plist");
    var items=[].slice.call(list.querySelectorAll(".pitem")),count=document.getElementById("count"),nores=document.getElementById("nores"),active="All";
    var yearSel=document.getElementById("year"),authorSel=document.getElementById("author");
    function apply(){var s=(q.value||"").trim().toLowerCase(),n=0;var yr=yearSel.value,au=authorSel.value;items.forEach(function(el){var okT=active==="All"||el.getAttribute("data-type")===active;var okS=!s||el.getAttribute("data-s").indexOf(s)!==-1;var okY=yr==="All"||el.getAttribute("data-year")===yr;var okA=au==="All"||("|"+el.getAttribute("data-authors")+"|").indexOf("|"+au+"|")!==-1;var show=okT&&okS&&okY&&okA;el.style.display=show?"":"none";if(show)n++;});var filtering=(s!==""||active!=="All"||yr!=="All"||au!=="All");count.style.display=filtering?"":"none";if(filtering)count.textContent=n+(n===1?" result":" results");nores.hidden=n!==0;}
    q.addEventListener("input",apply);
    yearSel.addEventListener("change",apply);
    authorSel.addEventListener("change",apply);
    document.getElementById("chips").addEventListener("click",function(e){var b=e.target.closest(".chip");if(!b)return;active=b.getAttribute("data-t");document.querySelectorAll("#chips .chip").forEach(function(c){c.classList.toggle("on",c===b);});apply();});
    document.addEventListener("click",function(e){var tog=e.target.closest(".pi-cite-toggle");if(tog){var links=tog.closest(".pi-links");var box=links&&links.nextElementSibling;if(box&&box.classList.contains("pi-cite-box")){var nowHidden=!box.hidden;box.hidden=nowHidden;tog.classList.toggle("on",!nowHidden);}return;}var b=e.target.closest(".pi-copy");if(!b)return;var pre=b.parentElement&&b.parentElement.querySelector(".pi-bib");if(!pre)return;var t=pre.textContent;(navigator.clipboard?navigator.clipboard.writeText(t):Promise.reject()).then(function(){var o=b.textContent;b.textContent="Copied!";b.classList.add("ok");setTimeout(function(){b.textContent=o;b.classList.remove("ok");},1500);}).catch(function(){var r=document.createRange();r.selectNodeContents(pre);var s=window.getSelection();s.removeAllRanges();s.addRange(r);});});
  })();
</script>
