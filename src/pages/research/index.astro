---
import Base from "../../layouts/Base.astro";
import lab from "../../data/lab.json";
import projects from "../../data/projects.json";
const base = import.meta.env.BASE_URL;
const u = (p) => base.replace(/\/$/, "") + "/" + p.replace(/^\//, "");
---
<Base title="Research" description="Research thrusts and funded projects of the CyReN Lab.">
  <section class="page-head">
    <div class="wrap"><span class="eyebrow">Research</span><h1 class="h-xl">Research</h1>
      <p class="lead">We build networks that stay secure and keep working under stress, attack, and uncertainty, from the wireless edge to autonomous systems.</p></div>
  </section>
  <section class="section">
    <div class="wrap thrusts">
      {lab.thrusts.map((t, i) => (
        <article class={"thrust reveal" + (i % 2 ? " flip" : "")}>
          <div class="thrust-img" style={`background-image:url('${u(t.image)}')`}></div>
          <div>
            <div class="thrust-num">0{i + 1}</div>
            <h2 class="h-md">{t.title}</h2>
            <p>{t.blurb}</p>
            <div class="tags">{t.tags.map((x) => <span class="tag">{x}</span>)}</div>
          </div>
        </article>
      ))}
    </div>
  </section>
  <section class="section section-alt">
    <div class="wrap"><span class="eyebrow">Projects</span><h2 class="h-lg" style="margin-bottom:1.6rem;">Ongoing projects</h2>
      <div class="projs">
        {projects.map((p, i) => (
          <article class="proj">
            <div class="proj-i">P{i + 1}</div>
            <div>
              <h3 class="h-md">{p.title}</h3>
              {p.sponsor && <div class="proj-sp">{p.sponsor}</div>}
              <p>{p.summary}</p>
              <div class="tags">{p.tags.map((x) => <span class="tag">{x}</span>)}</div>
            </div>
          </article>
        ))}
      </div>
      <a class="btn link-more" href={u("publications")}>See related publications →</a>
    </div>
  </section>
</Base>
<style>
  .page-head{padding:clamp(2.5rem,6vw,5rem) 0 0;}
  .thrusts{display:flex;flex-direction:column;gap:clamp(1.5rem,3vw,2.6rem);}
  .thrust{display:grid;grid-template-columns:1.05fr 1fr;gap:clamp(1.2rem,3vw,2.6rem);align-items:center;}
  .thrust.flip .thrust-img{order:2;}
  .thrust-img{height:300px;background-size:cover;background-position:center;border-radius:var(--radius);}
  .thrust-num{font-family:var(--ff-mono);font-size:13px;color:var(--maize-deep);margin-bottom:.4rem;}
  .tags{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.9rem;}
  .projs{display:flex;flex-direction:column;gap:1rem;}
  .proj{display:grid;grid-template-columns:54px 1fr;gap:1.2rem;background:#fff;border:1px solid var(--border);border-left:4px solid var(--maize);border-radius:var(--radius);padding:1.5rem;}
  .proj-i{font-family:var(--ff-mono);color:var(--link);font-size:1.2rem;}
  .proj-sp{font-family:var(--ff-mono);font-size:12px;color:var(--maize-deep);margin:.2rem 0 .5rem;}
  .link-more{margin-top:1.8rem;}
  @media(max-width:880px){.thrust{grid-template-columns:1fr;}.thrust.flip .thrust-img{order:0;}.thrust-img{height:220px;}.proj{grid-template-columns:1fr;gap:.5rem;}}
</style>
