---
import Base from "../../layouts/Base.astro";
import lab from "../../data/lab.json";
import team from "../../data/team.json";
const base = import.meta.env.BASE_URL;
const u = (p) => base.replace(/\/$/, "") + "/" + p.replace(/^\//, "");
const initials = (n) => n.split(" ").map((w) => w[0]).join("").slice(0, 2).toUpperCase();
---
<Base title="Team" description="The people of the CyReN Lab.">
  <section class="page-head"><div class="wrap"><span class="eyebrow">People</span><h1 class="h-xl">The team</h1></div></section>
  <section class="section">
    <div class="wrap">
      <a class="director" href={lab.director.url} target="_blank" rel="noopener">
        <div class="d-photo" style={`background-image:url('${u(lab.director.photo)}')`}></div>
        <div>
          <div class="eyebrow">Director</div>
          <h2 class="h-lg">{lab.director.name}</h2>
          <p>{lab.director.role}. Visit faculty page →</p>
        </div>
      </a>

      <h2 class="h-md sect">Researchers</h2>
      <div class="grid">
        {team.members.map((m) => (
          <article class="card">
            <a href={u("team/" + m.slug)} aria-label={m.name}><div class="c-photo" style={`background-image:url('${u(m.photo)}')`}></div></a>
            <a class="c-name" href={u("team/" + m.slug)}>{m.name}</a>
            <div class="c-role">{m.role}</div>
            <div class="c-focus">{m.focus}</div>
            <div class="c-links">
              <a href={u("team/" + m.slug)}>Profile →</a>
              {m.linkedin && <a href={m.linkedin} target="_blank" rel="noopener">LinkedIn ↗</a>}
            </div>
          </article>
        ))}
      </div>

      {team.alumni.length > 0 && (
        <div class="people-sec">
          <h2 class="h-md sect">Alumni</h2>
          <div class="people-grid">
            {team.alumni.map((a) => (
              <article class="person">
                <div class="p-av">
                  {a.photo && <img src={u(a.photo)} alt={a.name} loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='grid'" />}
                  <span class="p-ini" style={a.photo ? "display:none" : ""}>{initials(a.name)}</span>
                </div>
                <div>
                  {a.linkedin
                    ? <a class="p-name" href={a.linkedin} target="_blank" rel="noopener">{a.name}</a>
                    : <span class="p-name">{a.name}</span>}
                  {a.note && <div class="p-note">{a.note}</div>}
                  {a.year && <div class="p-year">{a.year}</div>}
                </div>
              </article>
            ))}
          </div>
        </div>
      )}

      {team.interns && team.interns.length > 0 && (
        <div class="people-sec">
          <h2 class="h-md sect">Interns & visiting researchers</h2>
          <div class="people-grid">
            {team.interns.map((a) => (
              <article class="person">
                <div class="p-av">
                  {a.photo && <img src={u(a.photo)} alt={a.name} loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='grid'" />}
                  <span class="p-ini" style={a.photo ? "display:none" : ""}>{initials(a.name)}</span>
                </div>
                <div>
                  {a.linkedin
                    ? <a class="p-name" href={a.linkedin} target="_blank" rel="noopener">{a.name}</a>
                    : <span class="p-name">{a.name}</span>}
                  {a.note && <div class="p-note">{a.note}</div>}
                </div>
              </article>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</Base>
<style>
  .page-head{padding:clamp(2.5rem,6vw,5rem) 0 0;}
  .director{display:grid;grid-template-columns:200px 1fr;gap:1.8rem;align-items:center;padding:1.6rem;border:1px solid var(--border);border-left:4px solid var(--maize);border-radius:var(--radius);margin-bottom:3rem;}
  .director:hover{text-decoration:none;border-color:var(--border-strong);}
  .d-photo{aspect-ratio:4/5;background-size:cover;background-position:center;border-radius:var(--radius);}
  .sect{margin-bottom:1.2rem;}
  .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.2rem;}
  .card{}
  .c-photo{aspect-ratio:4/5;background-size:cover;background-position:center;border-radius:var(--radius);margin-bottom:.7rem;filter:grayscale(.15);transition:filter .25s;}
  .card:hover .c-photo{filter:none;}
  .c-name{display:inline-block;font-family:var(--ff-serif);font-weight:600;color:var(--blue);font-size:1.1rem;}
  a.c-name:hover{color:var(--link);}
  .c-role{font-size:.82rem;color:var(--link);}
  .c-focus{font-size:.82rem;color:var(--text-mute);margin-top:.2rem;}
  .c-links{display:flex;gap:.9rem;margin-top:.5rem;}
  .c-links a{font-family:var(--ff-mono);font-size:12px;color:var(--link);}
  .people-sec{margin-top:2.6rem;border-top:1px solid var(--border);padding-top:2rem;}
  .people-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.1rem;margin-top:1rem;}
  .person{display:flex;gap:.9rem;align-items:center;}
  .p-av{width:60px;height:60px;flex:0 0 60px;border-radius:50%;overflow:hidden;background-color:var(--blue);}
  .p-av img{width:100%;height:100%;object-fit:cover;display:block;}
  .p-ini{width:100%;height:100%;display:grid;place-items:center;color:var(--maize);font-family:var(--ff-mono);font-size:16px;}
  .p-name{font-family:var(--ff-serif);font-weight:600;color:var(--blue);font-size:1.05rem;}
  a.p-name:hover{color:var(--link);}
  .p-note{font-size:.84rem;color:var(--text-mute);}
  .p-year{font-family:var(--ff-mono);font-size:.78rem;color:var(--link);margin-top:.1rem;}
  @media(max-width:880px){.director{grid-template-columns:1fr;}.grid{grid-template-columns:repeat(2,1fr);}}
  @media(max-width:620px){.people-grid{grid-template-columns:1fr;}}
</style>
