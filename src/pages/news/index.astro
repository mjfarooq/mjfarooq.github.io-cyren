---
import Base from "../../layouts/Base.astro";
import lab from "../../data/lab.json";
import news from "../../data/news.json";
import team from "../../data/team.json";
const base = import.meta.env.BASE_URL;
const u = (p) => base.replace(/\/$/, "") + "/" + p.replace(/^\//, "");
const linkMembers = team.members.filter((m) => m.slug);
const linkify = (t) => {
  let s = t;
  for (const m of linkMembers) s = s.split(m.name).join(`<a class="n-link" href="${u("team/" + m.slug)}">${m.name}</a>`);
  return s;
};
---
<Base title="News" description="Lab news, gallery, and openings.">
  <section class="page-head"><div class="wrap"><span class="eyebrow">News</span><h1 class="h-xl">News &amp; openings</h1></div></section>
  <section class="section">
    <div class="wrap news-grid">
      <ul class="news-list">
        {news.map((n) => (
          <li>
            <span class="n-date">{n.date}</span>
            <div class="n-body">
              <span class="n-text" set:html={linkify(n.text)}></span>
              {n.link && <a class="n-more" href={n.link} target="_blank" rel="noopener">Visit site →</a>}
              {n.images && n.images.length > 0 && (
                <div class="n-thumbs">
                  {n.images.map((src, i) => <img class="n-thumb" src={u(src)} data-gallery={JSON.stringify(n.images.map((s) => u(s)))} data-index={i} alt="" loading="lazy" onerror="this.style.display='none'" />)}
                </div>
              )}
            </div>
          </li>
        ))}
      </ul>
      <aside class="join-card" id="join">
        <h2 class="h-md">Join the lab</h2>
        <p>We are recruiting motivated Ph.D. and master's students interested in NextG networks, cyber resilience, and autonomous systems.</p>
        <a class="btn btn-maize" href={"mailto:" + lab.email}>Email {lab.email}</a>
      </aside>
    </div>
  </section>
</Base>
<style>
  .page-head{padding:clamp(2.5rem,6vw,5rem) 0 0;}
  .news-grid{display:grid;grid-template-columns:1.6fr 1fr;gap:clamp(1.5rem,4vw,3rem);align-items:start;}
  .news-list{list-style:none;padding:0;margin:0;}
  .news-list li{display:flex;gap:1rem;padding:1rem 0;border-top:1px solid var(--border);}
  .n-date{flex:0 0 84px;font-family:var(--ff-mono);font-size:12px;color:var(--link);padding-top:.15rem;}
  .n-body{flex:1;}
  .n-text{font-size:.95rem;color:var(--text);}
  .n-link{color:var(--link);font-weight:500;}
  .n-more{display:inline-block;font-family:var(--ff-mono);font-size:12px;color:var(--link);margin-top:.45rem;}
  .n-thumbs{display:flex;flex-wrap:wrap;gap:8px;margin-top:.7rem;}
  .n-thumb{width:120px;height:84px;object-fit:cover;object-position:top;border-radius:6px;border:1px solid var(--border);cursor:zoom-in;}
  @media(max-width:520px){.n-thumb{width:calc(50% - 4px);height:96px;}}
  .join-card{background:var(--blue);color:#fff;border-radius:var(--radius);padding:1.6rem;position:sticky;top:90px;}
  .join-card h2{color:#fff;margin-bottom:.6rem;}
  .join-card p{color:#cdd9e6;font-size:.92rem;}
  .gallery{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;}
  .g-fig{margin:0;}
  .g-img{aspect-ratio:4/3;background-size:cover;background-position:center;border-radius:var(--radius);cursor:zoom-in;}
  .g-fig figcaption{font-size:.82rem;color:var(--text-mute);margin-top:.4rem;font-family:var(--ff-mono);}
  @media(max-width:880px){.news-grid{grid-template-columns:1fr;}.join-card{position:static;}.gallery{grid-template-columns:repeat(2,1fr);}}
</style>
